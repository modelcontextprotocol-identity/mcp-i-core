{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "../../",
    "declaration": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "../../src/**/*",
    "../node-server/node-crypto.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
